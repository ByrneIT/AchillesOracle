# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development           # set to "production" on the server
SECRET_KEY=replace-with-a-secure-random-string   # required in production

# ── Database / Cache (future use) ──────────────────────────────────────────────
DATABASE_URL=sqlite:///./dev.db
REDIS_URL=redis://localhost:6379/0

# ── HashiCorp Vault (optional — leave blank to use env vars instead) ───────────
#VAULT_ADDR=https://vault.example.com
#VAULT_TOKEN=...

# ── Stripe (leave blank until paywall goes live) ───────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
#STRIPE_SECRET_KEY=sk_live_...
#STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get this from: Stripe Dashboard → Developers → Webhooks → your endpoint
#STRIPE_WEBHOOK_SECRET=whsec_...
# Get this from: Stripe Dashboard → Products → your plan → copy Price ID
#STRIPE_PRICE_ID=price_...
